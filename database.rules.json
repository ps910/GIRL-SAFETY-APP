{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",

        "sos_events": {
          "$eventId": {
            ".validate": "newData.hasChildren(['_syncedAt']) && (!newData.hasChild('latitude') || (newData.child('latitude').isNumber() && newData.child('latitude').val() >= -90 && newData.child('latitude').val() <= 90)) && (!newData.hasChild('longitude') || (newData.child('longitude').isNumber() && newData.child('longitude').val() >= -180 && newData.child('longitude').val() <= 180))",

            "delivery_confirmations": {
              "$confirmerUid": {
                ".write": "auth != null && auth.uid === $confirmerUid"
              }
            },
            "delivery_confirmed": {
              ".write": "auth != null"
            }
          }
        },

        "blocked": {
          "$targetUid": {
            ".validate": "newData.hasChildren(['uid', 'blockedAt'])"
          }
        },

        "profile": {
          ".validate": "newData.hasChildren()"
        }
      }
    },

    "admin": {
      ".read":  "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true",

      "active_sos": {
        "$eventId": {
          ".write": "auth != null && (auth.token.admin === true || newData.child('_uid').val() === auth.uid)"
        }
      },

      "devices": {
        "$uid": {
          ".write": "auth != null && (auth.token.admin === true || $uid === auth.uid)"
        }
      },

      "statistics": {
        ".read": "auth != null && auth.token.admin === true",
        ".write": "auth != null && auth.token.admin === true"
      },

      "reports": {
        ".read": "auth != null && auth.token.admin === true",
        "$reportId": {
          ".write": "auth != null && (!data.exists() || auth.token.admin === true)",
          ".validate": "newData.hasChildren(['reporterUid', 'targetUid', 'reason', 'status', 'createdAt'])"
        }
      }
    },

    "live_tracking": {
      "$sessionId": {
        ".read":  "auth != null || (data.exists() && data.child('isActive').val() === true && now < data.child('expiresAt').val())",
        ".write": "auth != null && (!data.exists() || data.child('ownerUid').val() === auth.uid) && (!newData.exists() || newData.child('ownerUid').val() === auth.uid)",
        ".validate": "newData.hasChildren(['ownerUid','expiresAt','isActive']) && newData.child('ownerUid').val() === auth.uid && newData.child('expiresAt').isNumber() && newData.child('expiresAt').val() > now && newData.child('expiresAt').val() < now + 86400000"
      }
    },

    "police_departments": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.admin === true"
    },

    "officers": {
      ".read": "auth != null",
      "$officerId": {
        ".write": "auth != null && (auth.token.admin === true || auth.uid === $officerId)"
      }
    },

    "case_assignments": {
      ".read": "auth != null && (auth.token.admin === true || auth.token.police === true)",
      ".write": "auth != null && auth.token.admin === true"
    },

    "case_responses": {
      ".read": "auth != null && (auth.token.admin === true || auth.token.police === true || data.child('userId').val() === auth.uid)",
      "$caseId": {
        ".write": "auth != null && (auth.token.police === true || auth.token.admin === true)"
      }
    },

    "crime_zones": {
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.admin === true || auth.token.police === true)",
      "$zoneId": {
        ".validate": "newData.hasChildren(['centerLat', 'centerLng', 'type', 'incidentCount'])"
      }
    },

    "community_alerts": {
      ".read": "auth != null",
      "$alertId": {
        ".write": "auth != null && (!data.exists() || data.child('victimUid').val() === auth.uid || auth.token.admin === true)",
        "helpers": {
          "$helperUid": {
            ".write": "auth != null && auth.uid === $helperUid"
          }
        },
        "liveLocation": {
          ".write": "auth != null && (data.parent().child('victimUid').val() === auth.uid || auth.token.admin === true)"
        }
      }
    },

    "case_database": {
      ".read": "auth != null && (auth.token.admin === true || auth.token.police === true)",
      ".write": "auth != null && (auth.token.admin === true || auth.token.police === true)"
    },

    "verification_queue": {
      ".read": "auth != null && auth.token.admin === true",
      "$userId": {
        ".write": "auth != null && (auth.uid === $userId || auth.token.admin === true)"
      }
    }
  }
}
